# --- 依赖目录 (最重要) ---
node_modules/
.pnp/
.pnp.js

# --- 构建产物/打包输出 ---
dist/
build/
out/
coverage/
.next/
.nuxt/

# --- Vite / 工具缓存 ---
.vite/
.cache/

# --- 编辑器/系统临时文件 ---
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.vscode/
.idea/
*.swp
*.swo

# --- 环境变量 (包含密码密钥，绝对不能提交) ---
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# --- ESLint / Stylelint 等缓存 ---
.eslintcache
.stylelintcache

# --- TypeScript / Vue 构建信息 ---
*.tsbuildinfo

# --- 测试报告（若以后加 Vitest / Playwright 等） ---
test-results/
playwright-report/

# --- 其它框架/文档 ---
.vuepress/dist

# --- Windows 杂项（可选） ---
ehthumbs.db
Desktop.ini
